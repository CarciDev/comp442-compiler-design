/*
1.1  Allocate memory for basic types (integer, float).
1.3  Allocate memory for objects.
2.1  Branch to a function's code block, execute, branch back.
2.2  Pass parameters as local values to the function's code block.
2.3  Upon execution of a return statement, pass the return value back.
2.4  Call to member functions that can use their object's data members.
3.1  Assignment statement.
3.4  Input/output statement.
4.3  For objects, access to members of basic types.
5.1  Computing the value of an entire complex expression.
5.3  Expression involving an object factor referring to object members.
*/

// Assignment 5 coverage:
//      -------------
//      | YES | NO  |
//      -------------
// 1.1: |  X  |     |
// 1.2: |     |  X  |
// 1.3: |  X  |     |
// 1.4: |     |  X  |
// 2.1: |  X  |     |
// 2.2: |  X  |     |
// 2.3: |  X  |     |
// 2.4: |  X  |     |
// 3.1: |  X  |     |
// 3.2: |     |  X  |
// 3.3: |     |  X  |
// 3.4: |  X  |     |
// 4.1: |     |  X  |
// 4.2: |     |  X  |
// 4.3: |  X  |     |
// 4.4: |     |  X  |
// 5.1: |  X  |     |
// 5.2: |     |  X  |
// 5.3: |  X  |     |
//      -------------

class POINT {
  public integer x;
  public integer y;
  public build(integer px, integer py) : POINT;
  public sum() : integer;
};

POINT::build(integer px, integer py) : POINT               // 2.1, 2.2
  local
    POINT p;                                               // 1.3
  do
    p.x = px;                                             // 3.1, 4.3, 5.3
    p.y = py;                                             // 3.1, 4.3, 5.3
    return (p);                                            // 2.3
  end;

POINT::sum() : integer                                     // 2.1, 2.4
  local
    integer result;                                        // 1.1
  do
    result = x + y;                                       // 3.1, 4.3, 5.1, 5.3
    return (result);                                       // 2.3
  end;

main
  local
    POINT p1;                                              // 1.3
    integer total;                                         // 1.1
  do
    p1 = p1.build(3, 4);                                   // 2.4, 2.2
    total = p1.sum();                                      // 2.4, 4.3, 5.3
    write(total);                                          // 3.4
    write(p1.x);                                           // 3.4, 4.3, 5.3
    write(p1.y);                                           // 3.4, 4.3, 5.3
  end
