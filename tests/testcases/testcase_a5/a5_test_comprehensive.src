/*
Comprehensive test covering ALL assignment 5 code generation items.
Tests: memory allocation (1.1-1.4), functions (2.1-2.4), statements (3.1-3.4),
aggregate access (4.1-4.4), expressions (5.1-5.3).
*/

// Assignment 5 coverage:
//      -------------
//      | YES | NO  |
//      -------------
// 1.1: |  X  |     |
// 1.2: |  X  |     |
// 1.3: |  X  |     |
// 1.4: |  X  |     |
// 2.1: |  X  |     |
// 2.2: |  X  |     |
// 2.3: |  X  |     |
// 2.4: |  X  |     |
// 3.1: |  X  |     |
// 3.2: |  X  |     |
// 3.3: |  X  |     |
// 3.4: |  X  |     |
// 4.1: |  X  |     |
// 4.2: |  X  |     |
// 4.3: |  X  |     |
// 4.4: |  X  |     |
// 5.1: |  X  |     |
// 5.2: |  X  |     |
// 5.3: |  X  |     |
//      -------------

// ====== class declarations ====== //
class Vec2 {
  public integer x;
  public integer y;
  public init(integer a, integer b) : Vec2;
  public length2() : integer;
};

class Particle {
  public Vec2 pos;
  public integer mass;
  public integer data[3];
  public create(integer px, integer py, integer m) : Particle;
  public getX() : integer;
};

// ====== member function implementations ====== //
Vec2::init(integer a, integer b) : Vec2                       // 2.1, 2.2
  local
    Vec2 v;                                                   // 1.3
  do
    v.x = a;                                                 // 3.1, 4.3, 5.3
    v.y = b;                                                 // 3.1, 4.3, 5.3
    return (v);                                               // 2.3
  end;

Vec2::length2() : integer                                     // 2.1, 2.4
  local
    integer result;                                           // 1.1
  do
    result = x * x + y * y;                                  // 3.1, 5.1, 5.3
    return (result);                                          // 2.3
  end;

Particle::create(integer px, integer py, integer m) : Particle  // 2.1, 2.2
  local
    Particle p;                                               // 1.3
  do
    p.pos = p.pos.init(px, py);                               // 2.4, 4.4, 5.3
    p.mass = m;                                              // 3.1, 4.3, 5.3
    p.data[0] = px;                                          // 3.1, 4.2, 4.4
    p.data[1] = py;                                          // 3.1, 4.2, 4.4
    p.data[2] = m;                                           // 3.1, 4.2, 4.4
    return (p);                                               // 2.3
  end;

Particle::getX() : integer                                    // 2.1, 2.4
  local
    integer result;                                           // 1.1
  do
    result = pos.x;                                          // 3.1, 4.3, 4.4, 5.3
    return (result);                                          // 2.3
  end;

/* free function to compute sum */
computeSum(integer values[], integer count) : integer          // 2.1, 2.2
  local
    integer total;                                            // 1.1
    integer idx;                                              // 1.1
  do
    total = 0;                                               // 3.1
    idx = 0;                                                 // 3.1
    while (idx < count)                                       // 3.3, 5.1
      do
        total = total + values[idx];                         // 3.1, 4.1, 5.1, 5.2
        idx = idx + 1;                                       // 3.1, 5.1
      end;
    return (total);                                           // 2.3
  end;

// ====== main ====== //
main
  local
    integer nums[5];                                          // 1.2
    integer result;                                           // 1.1
    integer i;                                                // 1.1
    Vec2 v;                                                   // 1.3
    Particle parts[2];                                        // 1.4
    Particle p1;                                              // 1.3
  do
    // Test 1.1, 3.1: basic integer allocation and assignment
    result = 0;                                              // 3.1
    i = 0;                                                   // 3.1

    // Test 1.2, 4.1, 5.2: array allocation and access
    nums[0] = 10;                                            // 3.1, 4.1
    nums[1] = 20;                                            // 3.1, 4.1
    nums[2] = 30;                                            // 3.1, 4.1
    nums[3] = 40;                                            // 3.1, 4.1
    nums[4] = 50;                                            // 3.1, 4.1

    // Test 5.2: array index is expression
    i = 2;                                                   // 3.1
    result = nums[i + 1];                                    // 5.2, 5.1, 4.1
    write(result);                                            // 3.4

    // Test 2.1-2.3: free function call with return
    result = computeSum(nums, 5);                             // 2.1, 2.2, 2.3
    write(result);                                            // 3.4

    // Test 5.1: complex expression
    result = (10 + 20) * 3 - 5;                              // 5.1
    write(result);                                            // 3.4

    // Test 3.2: conditional
    if (result > 50)                                          // 3.2, 5.1
    then
      do
        write(1);                                            // 3.4
      end
    else
      do
        write(0);                                            // 3.4
      end;

    // Test 3.3: loop
    i = 0;                                                   // 3.1
    while (i < 3)                                             // 3.3, 5.1
      do
        write(nums[i]);                                      // 3.4, 4.1, 5.2
        i = i + 1;                                           // 3.1, 5.1
      end;

    // Test 1.3, 2.4, 4.3, 5.3: object member access
    v = v.init(5, 12);                                        // 2.4, 1.3
    write(v.x);                                              // 3.4, 4.3, 5.3
    write(v.y);                                              // 3.4, 4.3, 5.3
    result = v.length2();                                     // 2.4, 5.3
    write(result);                                            // 3.4
  end
