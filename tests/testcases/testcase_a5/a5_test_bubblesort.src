/*
1.1  Allocate memory for basic types (integer, float).
1.2  Allocate memory for arrays of basic types.
2.1  Branch to a function's code block, execute, branch back.
2.2  Pass parameters as local values to the function's code block.
3.1  Assignment statement.
3.2  Conditional statement.
3.3  Loop statement.
3.4  Input/output statement.
4.1  For arrays of basic types, access to an array's elements.
5.1  Computing the value of an entire complex expression.
5.2  Expression involving an array factor whose indexes are themselves expressions.
*/

// Assignment 5 coverage:
//      -------------
//      | YES | NO  |
//      -------------
// 1.1: |  X  |     |
// 1.2: |  X  |     |
// 1.3: |     |  X  |
// 1.4: |     |  X  |
// 2.1: |  X  |     |
// 2.2: |  X  |     |
// 2.3: |     |  X  |
// 2.4: |     |  X  |
// 3.1: |  X  |     |
// 3.2: |  X  |     |
// 3.3: |  X  |     |
// 3.4: |  X  |     |
// 4.1: |  X  |     |
// 4.2: |     |  X  |
// 4.3: |     |  X  |
// 4.4: |     |  X  |
// 5.1: |  X  |     |
// 5.2: |  X  |     |
// 5.3: |     |  X  |
//      -------------

/* sort the array */
bubbleSort(integer arr[], integer size) : void             // 2.1, 2.2
  local
    integer n;                                             // 1.1
    integer i;                                             // 1.1
    integer j;                                             // 1.1
    integer temp;                                          // 1.1
  do
    n = size;                                             // 3.1
    i = 0;                                                // 3.1
    j = 0;                                                // 3.1
    temp = 0;                                             // 3.1
    while (i < n-1)
      do                                                   // 3.3, 5.1
        j = 0;                                            // 3.1
        while (j < n-i-1)
          do                                               // 3.3
            if (arr[j] > arr[j+1])                         // 3.2, 4.1, 5.1, 5.2
              then
                do
                  // swap temp and arr[i]
                  temp = arr[j];                          // 3.1, 4.1, 5.2
                  arr[j] = arr[j+1];                      // 3.1, 4.1, 5.2
                  arr[j+1] = temp;                        // 3.1, 4.1, 5.2
                end
              else
                do
                end;
              j = j+1;                                    // 3.1, 5.1
          end;
        i = i+1;                                          // 3.1, 5.1
      end;
  end;

/* print the array */
printArray(integer arr[], integer size) : void             // 2.1, 2.2
  local
    integer n;                                             // 1.1
    integer i;                                             // 1.1
  do
    n = size;                                             // 3.1
    i = 0;                                                // 3.1
    while (i<n)                                            // 3.3, 5.1
      do
        write(arr[i]);                                     // 3.4, 4.1, 5.2
        i = i+1;                                          // 3.1, 5.1
      end;
  end;

// main function to test above
main
  local
    integer arr[7];                                        // 1.2
  do
    arr[0] = 64;                                          // 3.1
    arr[1] = 34;                                          // 3.1
    arr[2] = 25;                                          // 3.1
    arr[3] = 12;                                          // 3.1
    arr[4] = 22;                                          // 3.1
    arr[5] = 11;                                          // 3.1
    arr[6] = 90;                                          // 3.1

    printArray(arr, 7);                                    // 2.1, 2.2
    bubbleSort(arr, 7);                                    // 2.1, 2.2
    printArray(arr, 7);                                    // 2.1, 2.2
  end
